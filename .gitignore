# Python
__pycache__/
*.py[cod]
.venv/
venv/

# macOS
.DS_Store
**/.DS_Store

# Media in/out — keep these out of git
clips/*
output/*
reports/
!clips/.gitkeep
!output/.gitkeep

# Cached Whisper transcripts (regenerated from clips on demand)
.transcripts/

# Cached window preview MP4s for the human review UI (review.py) — regenerated
.review/

# Workbench previews + edit project (workbench.py) and its exports — regenerated
.workbench/
montage/

# Model label store (training data) + trained student. Generated, can be large —
# kept out of git, but .labels/ is your hard-won training asset: back it up and
# sync it between machines (it's how the Mac<->PC handoff works).
.labels/
models/

